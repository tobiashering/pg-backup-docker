{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "timezone": "Europe/Berlin",
  "automerge": true,
  "packageRules": [
    {
      "description": "Disable auto-merge for major updates and replacement packages",
      "matchUpdateTypes": ["major", "replacement"],
      "automerge": false
    },
    {
      "description": "Add renovate label to all updates by default",
      "matchManagers": ["*"],
      "addLabels": ["renovate"]
    },
    {
      "description": "Label major updates",
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"]
    },
    {
      "description": "Label minor updates",
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor"]
    },
    {
      "description": "Label patch updates",
      "matchUpdateTypes": ["patch"],
      "addLabels": ["patch"]
    },
    {
      "description": "Label digest updates or pins",
      "matchUpdateTypes": ["digest", "pinDigest"],
      "addLabels": ["digest"]
    },
    {
      "description": "Label PostgreSQL updates",
      "matchPackageNames": ["pgautoupgrade/pgautoupgrade", "postgres"],
      "addLabels": ["postgres"]
    },
    {
      "description": "Docker",
      "matchDatasources": ["docker"],
      "addLabels": ["docker"],
      "pinDigests": true
    },
    {
      "description": "GitHub actions",
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "description": "Mise tools",
      "matchManagers": ["mise"],
      "addLabels": ["mise"]
    },
    {
      "groupName": "Docker digest pins",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["pinDigest"]
    },
    {
      "description": "Renovate",
      "groupName": "Renovate",
      "matchPackageNames": ["renovate", "ghcr.io/renovatebot/renovate"],
      "addLabels": ["renovate"],
      "schedule": "* 3-5 * * 1"
    },
    {
      "description": "Do not pin digests for docker-compose and custom regex managers",
      "matchManagers": ["docker-compose", "custom.regex"],
      "pinDigests": false
    },
    {
      "description": "Do not update postgres for custom regex managers",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": ["postgres_version:\\s*\"(?<currentValue>[^\"]*)\""],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker"
    }
  ]
}
